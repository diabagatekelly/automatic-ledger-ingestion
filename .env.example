# Copy to .env and fill in. NEVER commit the real .env.

# --- WhatsApp Cloud API ---
WHATSAPP_VERIFY_TOKEN=choose-a-random-string
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Meta App dashboard -> Settings -> Basic -> App secret. Used to verify each
# inbound POST's X-Hub-Signature-256 HMAC (#8). The handler fails closed without it.
WHATSAPP_APP_SECRET=

# --- Gemini (Google AI Studio API key) ---
GEMINI_API_KEY=
# Alias tracking the current free-tier Flash-Lite model — higher free quota /
# less throttling than full Flash, and accurate on short notes. Override to
# change, e.g. gemini-flash-latest or gemini-3.5-flash.
GEMINI_MODEL=gemini-flash-lite-latest

# --- Google Sheets ---
SHEET_ID=
# Local dev only; in the cloud, auth is via the function's service account.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
